{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TS18 Evidence Manifest",
  "type": "object",
  "required": ["deviceLabel","captureTimestampUtc","scenarioIdsAttempted","redactionStatus"],
  "properties": {
    "deviceLabel": {"type":"string"},
    "deviceFingerprint": {"type":"string"},
    "firmwareThemeLabel": {"type":"string"},
    "auxioBuild": {"type":"string"},
    "captureTimestampUtc": {"type":"string"},
    "scenarioIdsAttempted": {"type":"array","items":{"type":"string","pattern":"^TS18-STD-(00[1-9]|01[0-7])$"}},
    "redactionStatus": {"type":"string"},
    "scenarioEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioId", "status"],
        "properties": {
          "scenarioId": {
            "type": "string",
            "pattern": "^TS18-STD-(00[1-9]|01[0-7])$"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "blocked", "not captured", "requires manual review"]
          },
          "evidenceConfidence": {
            "type": "string",
            "enum": ["Observed", "Inferred", "Hypothesis", "Requires TS18 validation", "Unsupported"]
          },
          "portingDecision": {
            "type": "string",
            "enum": [
              "Directly reusable requirement",
              "Reusable validation idea",
              "Useful as evidence only",
              "Obsolete due to Auxio architecture",
              "Requires TS18 runtime validation",
              "Unsafe to port",
              "Should be explicitly avoided"
            ]
          },
          "rawEvidencePaths": {"type": "array", "items": {"type": "string"}},
          "derivedEvidencePaths": {"type": "array", "items": {"type": "string"}},
          "nativeInvestigationCandidate": {"type": "boolean"},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  }
}
