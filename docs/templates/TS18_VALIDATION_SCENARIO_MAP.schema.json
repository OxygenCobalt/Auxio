{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "scenarios"],
  "properties": {
    "version": {"type": "string"},
    "scenarios": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {
        "type": "object",
        "required": ["scenario_id","surface","goal","tier1_implementation","evidence_required","adb_commands","manual_steps","expected_android_standard_signal","expected_ts18_surface_signal","pass_condition","fail_condition","partial_condition","blocked_condition","matrix_row","native_investigation_trigger","confidence_label","porting_decision_label","severity","user_impact","native_investigation_priority"],
        "properties": {
          "scenario_id": {"type":"string","pattern":"^TS18-STD-(00[1-9]|01[0-7])$"},
          "surface": {"type":"string","minLength":1},
          "goal": {"type":"string","minLength":1},
          "tier1_implementation": {"type":"string","minLength":1},
          "evidence_required": {"type":"array","items":{"type":"string"},"minItems":1},
          "adb_commands": {"type":"array","items":{"type":"string"},"minItems":1},
          "manual_steps": {"type":"array","items":{"type":"string"},"minItems":1},
          "expected_android_standard_signal": {"type":"string"},
          "expected_ts18_surface_signal": {"type":"string"},
          "pass_condition": {"type":"string"},
          "fail_condition": {"type":"string"},
          "partial_condition": {"type":"string"},
          "blocked_condition": {"type":"string"},
          "matrix_row": {"type":"string"},
          "native_investigation_trigger": {"type":"string"},
          "confidence_label": {"enum":["Observed","Inferred","Hypothesis","Requires TS18 validation","Unsupported"]},
          "porting_decision_label": {"enum":["Directly reusable requirement","Reusable validation idea","Useful as evidence only","Obsolete due to Auxio architecture","Requires TS18 runtime validation","Unsafe to port","Should be explicitly avoided"]},
          "severity": {"enum":["low","medium","high","critical"]},
          "user_impact": {"enum":["low","degrades head-unit UX","blocks primary music use"]},
          "native_investigation_priority": {"enum":["low","medium","high"]}
        },
        "additionalProperties": false
      }
    }
  }
}
