<!-- Merge/adapt these into the Auxio-TS manifest or topwayTwMusic manifest overlay. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Needed only when targeting Android 14+ and using a media playback foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Needed only when targeting Android 13+ and posting notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <activity
            android:name="org.oxycblt.auxio.car.overlay.CarOverlayPermissionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <service
            android:name="org.oxycblt.auxio.car.overlay.CarFloatingControlsService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <receiver
            android:name="org.oxycblt.auxio.car.overlay.CarOverlayBootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
